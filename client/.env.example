# Supabase (public — safe in client bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# App URL (used in email links; no trailing slash)
NEXT_PUBLIC_APP_URL=

# Email (Nodemailer / Gmail SMTP)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# Optional — falls back to SMTP_USER if unset
SMTP_FROM=

# Signing secret for one-click email actions (server-only)
EMAIL_ACTION_SECRET=
